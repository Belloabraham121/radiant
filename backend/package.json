{
  "name": "radiant-backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "dev:inngest": "INNGEST_DEV=1 tsx watch src/main.ts",
    "inngest:dev": "npx --ignore-scripts=false inngest-cli@latest dev -u http://localhost:${PORT:-3001}/api/inngest",
    "predev": "prisma generate",
    "start": "tsx src/main.ts",
    "start:prod": "npm run db:deploy && tsx src/main.ts",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:deploy": "prisma migrate deploy && prisma generate",
    "db:check": "tsx scripts/check-db-schema.ts",
    "setup:privy-signer": "tsx scripts/setup-privy-signer.ts",
    "generate:vapid-keys": "tsx scripts/generate-vapid-keys.ts",
    "check": "tsc --noEmit && npm test",
    "test": "tsx --test tests/integration/**/*.test.ts tests/unit/**/*.test.ts",
    "test:integration": "tsx --test tests/integration/**/*.test.ts",
    "e2b:template:build": "tsx docker/e2b/build.prod.ts",
    "e2b:template:build:dev": "tsx docker/e2b/build.dev.ts",
    "e2b:smoke": "tsx docker/e2b/smoke.ts",
    "e2b:cleanup": "bash scripts/e2b-cleanup.sh",
    "e2b:cleanup:radiant": "tsx scripts/e2b-cleanup-radiant.ts",
    "e2b:cleanup:cron": "tsx scripts/e2b-cleanup-cron.ts",
    "e2b:cleanup:once": "E2B_CLEANUP_ONCE=true tsx scripts/e2b-cleanup-cron.ts",
    "e2b:webhook:register": "tsx scripts/e2b-register-webhook.ts",
    "walrus:check": "node scripts/walrus-setup-check.mjs",
    "worker:deploy": "tsx src/workers/deploy.worker.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.17.4",
    "@lifi/sdk": "^4.0.1",
    "@lifi/sdk-provider-ethereum": "^4.0.2",
    "@lifi/sdk-provider-solana": "^4.0.1",
    "@lifi/sdk-provider-sui": "^4.1.0",
    "@mysten/deepbook-v3": "^1.4.1",
    "@mysten/sui": "^2.17.0",
    "@prisma/client": "^6.5.0",
    "@privy-io/node": "^0.7.0",
    "@solana/web3.js": "^1.98.4",
    "@stellar/stellar-sdk": "^13.3.0",
    "bullmq": "^5.78.0",
    "cheerio": "^1.2.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "cron-parser": "^5.4.0",
    "dotenv": "^16.4.7",
    "e2b": "^2.29.1",
    "express": "^4.21.2",
    "helmet": "^8.2.0",
    "inngest": "^4.5.1",
    "ioredis": "^5.11.1",
    "openai": "^6.42.0",
    "viem": "^2.52.2",
    "web-push": "^3.6.7",
    "winston": "^3.17.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/helmet": "^4.0.0",
    "@types/ioredis": "^4.28.10",
    "@types/node": "^22.13.10",
    "@types/web-push": "^3.6.4",
    "prisma": "^6.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
