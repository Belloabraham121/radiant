{
  "name": "radiant-backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "tsx src/main.ts",
    "start:prod": "npm run db:deploy && tsx src/main.ts",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:deploy": "prisma migrate deploy && prisma generate",
    "db:check": "tsx scripts/check-db-schema.ts",
    "setup:privy-signer": "tsx scripts/setup-privy-signer.ts",
    "test": "tsx --test tests/integration/**/*.test.ts tests/unit/**/*.test.ts",
    "test:integration": "tsx --test tests/integration/**/*.test.ts"
  },
  "dependencies": {
    "@mysten/sui": "^2.17.0",
    "@prisma/client": "^6.5.0",
    "@privy-io/node": "^0.7.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "viem": "^2.52.2",
    "winston": "^3.17.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.10",
    "prisma": "^6.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
