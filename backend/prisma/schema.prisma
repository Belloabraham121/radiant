generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ChatMessageRole {
  user
  assistant
  system
  tool
}

enum AgentTransactionStatus {
  pending_approval
  rejected
  expired
  submitted
  success
  failure
}

enum AgentTransactionCategory {
  swap
  transfer
  deepbook_balance
  deepbook_order
  deepbook_cancel
  deepbook_modify
  deepbook_settled
  flash_loan
  stake
  governance
  margin
  predict
  other
}

model User {
  id            BigInt   @id @default(autoincrement())
  privy_user_id String   @unique
  email         String?  @unique
  display_name  String?
  avatar_seed   String
  avatar_style  String   @default("lorelei")
  /// When false, every swap and transfer requires in-app approval.
  agent_auto_approve_enabled Boolean @default(true)
  /// Max SUI notional for auto-approved swaps/transfers (display units).
  agent_auto_approve_max_sui Float    @default(25)
  /// When true, agent may initiate DeepBook flash loans (always require approval).
  agent_allow_flash_loans    Boolean  @default(false)
  /// When true, swap_chain_repay flash loans with swap_output repay may skip approval dialog.
  agent_auto_approve_flash_loans Boolean @default(false)
  /// When true, agent may submit DeepBook governance proposals and vote (always require approval).
  agent_allow_governance       Boolean  @default(false)
  /// When true, agent may use margin trading (deposit, borrow, leveraged orders).
  agent_allow_margin           Boolean  @default(false)
  /// When true, agent may use prediction markets (mint/redeem positions).
  agent_allow_predict          Boolean  @default(false)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  agent_wallets            AgentWallet[]
  chat_sessions            ChatSession[]
  agent_transactions       AgentTransaction[]
  agent_memory             AgentMemory?
  deepbook_balance_manager DeepBookBalanceManager?
  deepbook_margin_supplier_cap DeepBookMarginSupplierCap?
  deepbook_margin_supply_referrals DeepBookMarginSupplyReferral[]
  projects                 Project[]
  app_installations        AppInstallation[]
  notification_push_subscriptions NotificationPushSubscription[]
  notification_preference  NotificationPreference?
  notification_rules       NotificationRule[]
  notification_events      NotificationEvent[]
}

model AgentMemory {
  user_id    BigInt   @id
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  data       Json     @default("{}")
  updated_at DateTime @updatedAt
}

model ChatSession {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    BigInt
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  title      String   @default("New chat")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  messages           ChatMessage[]
  agent_transactions AgentTransaction[]
  projects           Project[]
  draft              ChatSessionDraft?
  agent_state        AgentSessionState?

  @@index([user_id, updated_at(sort: Desc)])
}

/**
 * Durable snapshot of in-flight agent session state (pending clarification +
 * paused workflow run) so it survives server restarts/deploys and works across
 * instances. One row per chat session; the runtime keeps a fast in-memory copy
 * and rehydrates from here on a cache miss.
 */
model AgentSessionState {
  session_id    String      @id @db.Uuid
  session       ChatSession @relation(fields: [session_id], references: [id], onDelete: Cascade)
  clarification Json?
  workflow      Json?
  created_at    DateTime    @default(now())
  updated_at    DateTime    @updatedAt

  @@index([updated_at])
}

model ChatSessionDraft {
  id         String   @id @default(uuid()) @db.Uuid
  session_id String   @unique @db.Uuid
  session    ChatSession @relation(fields: [session_id], references: [id], onDelete: Cascade)
  name       String
  tagline    String   @default("")
  template   String
  revision   Int      @default(0)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  files      ChatSessionDraftFile[]
}

model ChatSessionDraftFile {
  id         String           @id @default(uuid()) @db.Uuid
  draft_id   String           @db.Uuid
  draft      ChatSessionDraft @relation(fields: [draft_id], references: [id], onDelete: Cascade)
  path       String
  content    String           @db.Text
  revision   Int
  created_at DateTime         @default(now())

  @@unique([draft_id, path, revision])
  @@index([draft_id, revision])
}

model ChatMessage {
  id         String          @id @default(uuid()) @db.Uuid
  session_id String          @db.Uuid
  session    ChatSession     @relation(fields: [session_id], references: [id], onDelete: Cascade)
  role       ChatMessageRole
  content    String
  tool_calls         Json?
  app_scope          Json?
  created_at         DateTime            @default(now())
  agent_transactions AgentTransaction[]

  @@index([session_id, created_at(sort: Asc)])
}

/// Ledger of on-chain actions initiated by the user's agent wallet via chat.
model AgentTransaction {
  id                  String                   @id @default(uuid()) @db.Uuid
  user_id             BigInt
  user                User                     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  session_id          String?                  @db.Uuid
  session             ChatSession?             @relation(fields: [session_id], references: [id], onDelete: SetNull)
  message_id          String?                  @db.Uuid
  message             ChatMessage?             @relation(fields: [message_id], references: [id], onDelete: SetNull)
  workflow_step_index Int?
  chain_id            String
  wallet_address      String
  action              String
  params              Json
  category            AgentTransactionCategory
  title               String
  amount_display      String
  status              AgentTransactionStatus
  digest              String?
  effects_status      String?
  result              Json?
  error_code          String?
  error_message       String?
  created_at          DateTime                 @default(now())
  submitted_at        DateTime?
  completed_at        DateTime?

  @@unique([digest])
  @@index([user_id, created_at(sort: Desc)])
  @@index([user_id, status, created_at(sort: Desc)])
  @@index([user_id, category, created_at(sort: Desc)])
  @@index([session_id, created_at(sort: Asc)])
}

model DeepBookBalanceManager {
  id                String   @id @default(uuid()) @db.Uuid
  user_id           BigInt   @unique
  user              User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  chain_id          String   @default("sui")
  manager_object_id String
  manager_key       String
  trade_cap_id      String?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt
}

model DeepBookMarginSupplierCap {
  id                     String   @id @default(uuid()) @db.Uuid
  user_id                BigInt   @unique
  user                   User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  chain_id               String   @default("sui")
  supplier_cap_object_id String
  created_at             DateTime @default(now())
  updated_at             DateTime @updatedAt
}

model DeepBookMarginSupplyReferral {
  id                   String   @id @default(uuid()) @db.Uuid
  user_id              BigInt
  user                 User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  chain_id             String   @default("sui")
  coin_key             String
  referral_object_id   String
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  @@unique([user_id, coin_key])
}

model AgentWallet {
  id              BigInt   @id @default(autoincrement())
  user_id         BigInt
  user            User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  chain_type      String
  address         String
  privy_wallet_id String   @unique
  signer_added    Boolean  @default(false)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@unique([user_id, chain_type])
  @@unique([chain_type, address])
}

enum ProjectStatus {
  draft
  building
  deploying
  live
  failed
}

enum DeployJobStatus {
  queued
  running
  completed
  failed
  cancelled
}

model Project {
  id                 String        @id @default(uuid()) @db.Uuid
  user_id            BigInt
  user               User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  session_id         String?       @db.Uuid
  session            ChatSession?  @relation(fields: [session_id], references: [id], onDelete: SetNull)
  name               String
  tagline            String        @default("")
  template           String
  status             ProjectStatus @default(draft)
  accent             String        @default("#8e5bff")
  template_params    Json          @default("{}")
  package_id         String?
  walrus_url         String?
  walrus_blob_id     String?
  registry_object_id String?
  is_public          Boolean       @default(false)
  fee_bps            Int           @default(0)
  category           String        @default("payments")
  artifact_revision  Int           @default(0)
  action_schema      Json?
  notification_schema Json?
  created_at         DateTime      @default(now())
  updated_at         DateTime      @updatedAt
  files              ArtifactFile[]
  deploy_jobs        DeployJob[]
  installations      AppInstallation[] @relation("InstallSource")

  @@index([user_id, updated_at(sort: Desc)])
  @@index([is_public, created_at(sort: Desc)])
}

model AppInstallation {
  id                String   @id @default(uuid()) @db.Uuid
  user_id           BigInt
  user              User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  source_project_id String   @db.Uuid
  source_project    Project  @relation("InstallSource", fields: [source_project_id], references: [id], onDelete: Cascade)
  pinned_revision   Int?
  installed_at      DateTime @default(now())
  updated_at        DateTime @updatedAt

  @@unique([user_id, source_project_id])
  @@index([user_id, installed_at(sort: Desc)])
  @@index([source_project_id])
}

model ArtifactFile {
  id         String   @id @default(uuid()) @db.Uuid
  project_id String   @db.Uuid
  project    Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  path       String
  content    String
  revision   Int
  created_at DateTime @default(now())

  @@unique([project_id, path, revision])
  @@index([project_id, revision])
}

/// Per-installation app data — personal storage for generated apps (Phase 1: Postgres, Phase 2: Turso).
model AppData {
  id              String          @id @default(uuid()) @db.Uuid
  project_id      String          @db.Uuid
  installation_id String?         @db.Uuid
  user_id         BigInt
  collection      String          @db.VarChar(100)
  key             String?         @db.VarChar(255)
  data            Json
  created_at      DateTime        @default(now())
  updated_at      DateTime        @updatedAt

  @@unique([project_id, user_id, collection, key])
  @@index([project_id, user_id, collection, created_at(sort: Desc)])
  @@index([project_id, installation_id, collection, created_at(sort: Desc)])
}

model DeployJob {
  id                  String          @id @default(uuid()) @db.Uuid
  project_id          String          @db.Uuid
  project             Project         @relation(fields: [project_id], references: [id], onDelete: Cascade)
  status              DeployJobStatus @default(queued)
  provider            String
  sandbox_id          String?
  sandbox_seconds     Int?
  estimated_cost_usd  Decimal?        @db.Decimal(10, 6)
  logs                String          @default("")
  error_message       String?
  artifact_revision   Int
  started_at          DateTime?
  finished_at         DateTime?
  created_at          DateTime        @default(now())

  @@index([project_id, created_at(sort: Desc)])
  @@index([status])
}

enum NotificationChannelType {
  in_app
  web_push
  email
}

enum NotificationRuleStatus {
  active
  paused
  expired
  deleted
}

enum NotificationRuleSource {
  user
  agent
  app
  system
}

enum NotificationTriggerKind {
  event
  poll
  schedule
}

enum NotificationDeliveryStatus {
  pending
  sent
  failed
  skipped
  read
}

model NotificationPushSubscription {
  id           String    @id @default(uuid()) @db.Uuid
  user_id      BigInt
  user         User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  endpoint     String    @unique
  p256dh       String
  auth         String
  user_agent   String?
  created_at   DateTime  @default(now())
  last_used_at DateTime?
  revoked_at   DateTime?

  @@index([user_id])
}

model NotificationPreference {
  user_id           BigInt   @id
  user              User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  enabled           Boolean  @default(true)
  timezone          String   @default("UTC")
  quiet_hours_start String?  @db.VarChar(5)
  quiet_hours_end   String?  @db.VarChar(5)
  max_per_hour      Int      @default(10)
  default_channels  Json     @default("[\"in_app\",\"web_push\"]")
  updated_at        DateTime @updatedAt
}

model NotificationRule {
  id                String                   @id @default(uuid()) @db.Uuid
  user_id           BigInt
  user              User                     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  project_id        String?                  @db.Uuid
  installation_id   String?                  @db.Uuid
  source            NotificationRuleSource
  session_id        String?                  @db.Uuid
  label             String?                  @db.VarChar(120)
  notification_type String                   @db.VarChar(120)
  trigger_kind      NotificationTriggerKind
  condition         Json                     @default("{}")
  schedule          Json?
  channels          Json                     @default("[\"in_app\",\"web_push\"]")
  status            NotificationRuleStatus   @default(active)
  cooldown_seconds  Int                      @default(300)
  trigger_once      Boolean                  @default(false)
  last_triggered_at DateTime?
  expires_at        DateTime?
  created_at        DateTime                 @default(now())
  updated_at        DateTime                 @updatedAt

  events            NotificationEvent[]

  @@index([user_id, status])
  @@index([project_id, notification_type, status])
  @@index([installation_id, status])
  @@index([notification_type, status, trigger_kind])
}

model NotificationEvent {
  id                String            @id @default(uuid()) @db.Uuid
  user_id           BigInt
  user              User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  rule_id           String?           @db.Uuid
  rule              NotificationRule? @relation(fields: [rule_id], references: [id], onDelete: SetNull)
  project_id        String?           @db.Uuid
  installation_id   String?           @db.Uuid
  notification_type String            @db.VarChar(120)
  title             String
  body              String            @db.Text
  payload           Json              @default("{}")
  idempotency_key   String?           @unique
  created_at        DateTime          @default(now())

  deliveries        NotificationDelivery[]

  @@index([user_id, created_at(sort: Desc)])
  @@index([rule_id])
}

model NotificationDelivery {
  id           String                     @id @default(uuid()) @db.Uuid
  event_id     String                     @db.Uuid
  event        NotificationEvent          @relation(fields: [event_id], references: [id], onDelete: Cascade)
  channel      NotificationChannelType
  status       NotificationDeliveryStatus @default(pending)
  error        String?
  external_ref String?
  sent_at      DateTime?
  read_at      DateTime?

  @@index([event_id])
  @@index([status, channel])
}
