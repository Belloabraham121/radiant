generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ChatMessageRole {
  user
  assistant
  system
  tool
}

model User {
  id            BigInt   @id @default(autoincrement())
  privy_user_id String   @unique
  email         String?  @unique
  display_name  String?
  avatar_seed   String
  avatar_style  String   @default("lorelei")
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  agent_wallets            AgentWallet[]
  chat_sessions            ChatSession[]
  agent_memory             AgentMemory?
  deepbook_balance_manager DeepBookBalanceManager?
}

model AgentMemory {
  user_id    BigInt   @id
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  data       Json     @default("{}")
  updated_at DateTime @updatedAt
}

model ChatSession {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    BigInt
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  title      String   @default("New chat")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  messages ChatMessage[]

  @@index([user_id, updated_at(sort: Desc)])
}

model ChatMessage {
  id         String          @id @default(uuid()) @db.Uuid
  session_id String          @db.Uuid
  session    ChatSession     @relation(fields: [session_id], references: [id], onDelete: Cascade)
  role       ChatMessageRole
  content    String
  tool_calls Json?
  created_at DateTime        @default(now())

  @@index([session_id, created_at(sort: Asc)])
}

model DeepBookBalanceManager {
  id                String   @id @default(uuid()) @db.Uuid
  user_id           BigInt   @unique
  user              User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  chain_id          String   @default("sui")
  manager_object_id String
  manager_key       String
  trade_cap_id      String?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt
}

model AgentWallet {
  id              BigInt   @id @default(autoincrement())
  user_id         BigInt
  user            User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  chain_type      String
  address         String
  privy_wallet_id String   @unique
  signer_added    Boolean  @default(false)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@unique([user_id, chain_type])
  @@unique([chain_type, address])
}
