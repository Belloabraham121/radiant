generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ChatMessageRole {
  user
  assistant
  system
  tool
}

enum AgentTransactionStatus {
  pending_approval
  rejected
  expired
  submitted
  success
  failure
}

enum AgentTransactionCategory {
  swap
  transfer
  deepbook_balance
  deepbook_order
  deepbook_cancel
  deepbook_modify
  deepbook_settled
  flash_loan
  stake
  governance
  other
}

model User {
  id            BigInt   @id @default(autoincrement())
  privy_user_id String   @unique
  email         String?  @unique
  display_name  String?
  avatar_seed   String
  avatar_style  String   @default("lorelei")
  /// When false, every swap and transfer requires in-app approval.
  agent_auto_approve_enabled Boolean @default(true)
  /// Max SUI notional for auto-approved swaps/transfers (display units).
  agent_auto_approve_max_sui Float    @default(25)
  /// When true, agent may initiate DeepBook flash loans (always require approval).
  agent_allow_flash_loans    Boolean  @default(false)
  /// When true, swap_chain_repay flash loans with swap_output repay may skip approval dialog.
  agent_auto_approve_flash_loans Boolean @default(false)
  /// When true, agent may submit DeepBook governance proposals and vote (always require approval).
  agent_allow_governance       Boolean  @default(false)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  agent_wallets            AgentWallet[]
  chat_sessions            ChatSession[]
  agent_transactions       AgentTransaction[]
  agent_memory             AgentMemory?
  deepbook_balance_manager DeepBookBalanceManager?
}

model AgentMemory {
  user_id    BigInt   @id
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  data       Json     @default("{}")
  updated_at DateTime @updatedAt
}

model ChatSession {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    BigInt
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  title      String   @default("New chat")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  messages           ChatMessage[]
  agent_transactions AgentTransaction[]

  @@index([user_id, updated_at(sort: Desc)])
}

model ChatMessage {
  id         String          @id @default(uuid()) @db.Uuid
  session_id String          @db.Uuid
  session    ChatSession     @relation(fields: [session_id], references: [id], onDelete: Cascade)
  role       ChatMessageRole
  content    String
  tool_calls         Json?
  created_at         DateTime            @default(now())
  agent_transactions AgentTransaction[]

  @@index([session_id, created_at(sort: Asc)])
}

/// Ledger of on-chain actions initiated by the user's agent wallet via chat.
model AgentTransaction {
  id                  String                   @id @default(uuid()) @db.Uuid
  user_id             BigInt
  user                User                     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  session_id          String?                  @db.Uuid
  session             ChatSession?             @relation(fields: [session_id], references: [id], onDelete: SetNull)
  message_id          String?                  @db.Uuid
  message             ChatMessage?             @relation(fields: [message_id], references: [id], onDelete: SetNull)
  workflow_step_index Int?
  chain_id            String
  wallet_address      String
  action              String
  params              Json
  category            AgentTransactionCategory
  title               String
  amount_display      String
  status              AgentTransactionStatus
  digest              String?
  effects_status      String?
  result              Json?
  error_code          String?
  error_message       String?
  created_at          DateTime                 @default(now())
  submitted_at        DateTime?
  completed_at        DateTime?

  @@unique([digest])
  @@index([user_id, created_at(sort: Desc)])
  @@index([user_id, status, created_at(sort: Desc)])
  @@index([user_id, category, created_at(sort: Desc)])
  @@index([session_id, created_at(sort: Asc)])
}

model DeepBookBalanceManager {
  id                String   @id @default(uuid()) @db.Uuid
  user_id           BigInt   @unique
  user              User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  chain_id          String   @default("sui")
  manager_object_id String
  manager_key       String
  trade_cap_id      String?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt
}

model AgentWallet {
  id              BigInt   @id @default(autoincrement())
  user_id         BigInt
  user            User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  chain_type      String
  address         String
  privy_wallet_id String   @unique
  signer_added    Boolean  @default(false)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@unique([user_id, chain_type])
  @@unique([chain_type, address])
}
